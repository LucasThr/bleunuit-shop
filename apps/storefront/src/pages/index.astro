---
import Layout from "../layouts/Layout.astro";
import ProductCard from "../components/ProductCard.astro";
import {
  getAllBrands,
  getAllCategories,
  getFeaturedProducts,
} from "../utils/catalog-client";
import { getHomepage, getAllStores, getTestimonials } from "../utils/cms-client";
import { mapProductToCard } from "../utils/product-card";
import { slugFor } from "../utils/slugs";

// Every call degrades independently: if a collection is missing (migration
// not run yet) or Directus is down, the hardcoded fallbacks below render.
const logFail = (section: string) => (error: unknown) => {
  console.error(`Homepage: failed to load ${section} from Directus`, error);
  return null;
};
const [products, categories, brandsData, homepage, testimonialsData, storesData] =
  await Promise.all([
    getFeaturedProducts(4).catch(logFail("products")),
    getAllCategories().catch(logFail("categories")),
    getAllBrands().catch(logFail("brands")),
    getHomepage().catch(logFail("homepage")),
    getTestimonials().catch(logFail("testimonials")),
    getAllStores().catch(logFail("stores")),
  ]);

const featuredProducts = (products ?? []).map(mapProductToCard);

const hero = {
  badge: homepage?.hero_badge || "Depuis 1994",
  location: homepage?.hero_location || "Bruay-la-Buissière",
  title: homepage?.hero_title || "Votre plus belle nuit commence en magasin.",
  subtitle:
    homepage?.hero_subtitle ||
    "Matelas, sommiers et accessoires à essayer en conditions réelles, guidés par nos conseillers.",
  image: homepage?.hero_image || "/images/design/hero-bedroom.jpg",
};

// The first sleep-related word of the title gets a warm accent.
const heroAccentSplit = /\b(nuits?|sommeil|confort)\b/i;
const heroAccentExact = /^(nuits?|sommeil|confort)$/i;
const heroTitleParts = hero.title.split(heroAccentSplit);

const valueProps = homepage?.value_props?.length
  ? homepage.value_props
  : [
      {
        eyebrow: "Savoir-faire",
        title: "30 ans d'expertise locale.",
        description:
          "Nos conseillers accompagnent chaque profil de dormeur pour un choix durable et adapté à vos habitudes.",
      },
      {
        eyebrow: "Sélection rigoureuse",
        title: "Des marques reconnues.",
        description:
          "Technologies hybrides, ressorts ensachés, mousses haute résilience: nous filtrons le meilleur.",
      },
      {
        eyebrow: "Expérience magasin",
        title: "Essayez avant de choisir.",
        description:
          "Des espaces dédiés au confort pour ressentir la différence et comparer avec l'aide de nos experts.",
      },
    ];
const valuePropAccents = ["text-royal", "text-blue-500", "text-marine"];

const method = {
  title: homepage?.method_title || "Un parcours simple, guidé par l'humain.",
  intro:
    homepage?.method_intro ||
    "Un achat literie, ça se vit. Nous vous guidons et simplifions chaque étape, de l'essai au suivi.",
  steps: homepage?.method_steps?.length
    ? homepage.method_steps
    : [
        {
          title: "Écoute et diagnostic",
          description:
            "Nous analysons votre position de sommeil, vos douleurs et vos préférences de fermeté.",
        },
        {
          title: "Sélection accompagnée",
          description:
            "Essayez plusieurs conforts et comparez les technologies en conditions réelles.",
        },
        {
          title: "Livraison et suivi",
          description:
            "Nous organisons la livraison, la reprise et restons disponibles après installation.",
        },
      ],
};

const cta = {
  title: homepage?.cta_title || "Besoin de conseils personnalisés ?",
  text:
    homepage?.cta_text ||
    "Notre équipe vous accueille en magasin pour choisir la literie qui soutient vraiment votre sommeil.",
};

const testimonials = testimonialsData?.length
  ? testimonialsData.map((t) => ({ quote: t.quote, name: t.name, city: t.city }))
  : [
      {
        quote:
          "Un accompagnement précis et bienveillant. Nous avons trouvé un matelas parfaitement adapté.",
        name: "Camille et Hugo",
        city: "Bruay-la-Buissière",
      },
    ];

const staticStoreImages: Record<string, string> = {
  "bruay-la-buissiere": "/images/stores/bruay-la-buissiere.jpg",
};
const storeCards = storesData?.length
  ? storesData.map((store) => ({
      name: store.city || store.name,
      description:
        store.description ||
        "Un espace dédié au confort pour découvrir notre gamme avec nos conseillers.",
      image:
        store.image ||
        staticStoreImages[store.slug] ||
        "/images/stores/bruay-la-buissiere.jpg",
    }))
  : [
      {
        name: "Bruay-la-Buissière",
        description:
          "Un espace chaleureux avec un large choix de literies pour comparer sereinement.",
        image: staticStoreImages["bruay-la-buissiere"],
      },
    ];

const featuredCategories = (categories ?? []).slice(0, 4);
const fallbackCategories = [
  {
    name: "Matelas",
    description:
      "Soutien précis, confort durable et technologie adaptée à votre sommeil.",
    href: "/produits",
  },
  {
    name: "Sommiers",
    description: "Des bases stables pour prolonger la vie de votre literie.",
    href: "/produits",
  },
  {
    name: "Têtes de lit",
    description: "Un style chaleureux pour finaliser votre chambre.",
    href: "/produits",
  },
  {
    name: "Accessoires",
    description: "Oreillers, protections et linge pour un confort complet.",
    href: "/produits",
  },
];

const categoriesToShow = featuredCategories.length
  ? featuredCategories.map((category) => ({
      ...category,
      href: `/produits/${slugFor(category)}`,
    }))
  : fallbackCategories;

const categoryThemes = [
  {
    accent: "from-gold to-gold/40",
    iconBg: "bg-gold/20",
    badge: "text-marine",
  },
  {
    accent: "from-blue-400 to-blue-200",
    iconBg: "bg-blue-100",
    badge: "text-marine",
  },
  {
    accent: "from-blue-600 to-blue-400",
    iconBg: "bg-blue-100",
    badge: "text-marine",
  },
  {
    accent: "from-marine to-blue-600",
    iconBg: "bg-blue-100",
    badge: "text-marine",
  },
];

const featuredBrands = (brandsData ?? [])
  .filter((brand) => brand.name)
  .slice(0, 6)
  .map((brand) => ({
    name: brand.name,
    logo: brand.logo || null,
  }));
---

<Layout
  title="Accueil"
  description="Literie Bleunuit - Spécialiste literie depuis 1994. Découvrez nos matelas, sommiers et accessoires pour un sommeil de qualité à Bruay-la-Buissière."
>
  <!-- Hero -->
  <section
    class="relative isolate flex min-h-[clamp(32rem,82vh,46rem)] items-end overflow-hidden text-white"
  >
    <!-- Full-bleed bedroom photo -->
    <img
      src={hero.image}
      alt="Chambre apaisante équipée d'une literie Bleunuit"
      class="absolute inset-0 -z-10 h-full w-full object-cover"
      width="1920"
      height="1280"
      fetchpriority="high"
      decoding="async"
    />
    <!-- "Bleu nuit" scrim, darkest where the text sits for legibility -->
    <div
      class="absolute inset-0 -z-10 bg-gradient-to-t from-blue-900/85 via-blue-900/40 to-blue-900/10"
      aria-hidden="true"
    >
    </div>

    <div
      class="home-sans relative mx-auto w-full max-w-7xl px-4 pb-16 sm:px-6 sm:pb-20 lg:px-8 lg:pb-24"
    >
      <div class="max-w-2xl">
        <p
          class="hero-rise flex flex-wrap items-center gap-2.5 text-[11px] font-semibold uppercase tracking-[0.28em] text-white/80"
        >
          <svg
            class="h-3.5 w-3.5 text-gold"
            viewBox="0 0 24 24"
            fill="currentColor"
            aria-hidden="true"
          >
            <path d="M21 12.8A9 9 0 1 1 11.2 3a7 7 0 0 0 9.8 9.8z"></path>
          </svg>
          {hero.badge}
          <span class="text-white/40">·</span>
          {hero.location}
        </p>

        <h1
          class="home-display hero-rise mt-6 text-balance text-[2.7rem] font-semibold leading-[1.04] drop-shadow-[0_2px_18px_rgba(4,10,25,0.45)] sm:text-6xl lg:text-[4.25rem]"
          style="animation-delay: 90ms"
        >
          {
            heroTitleParts.map((part) =>
              heroAccentExact.test(part) ? (
                <span class="hero-accent">{part}</span>
              ) : (
                part
              )
            )
          }
        </h1>

        <p
          class="hero-rise mt-6 max-w-xl text-lg leading-relaxed text-white/85 drop-shadow-[0_1px_10px_rgba(4,10,25,0.4)]"
          style="animation-delay: 170ms"
        >
          {hero.subtitle}
        </p>

        <div
          class="hero-rise mt-9 flex flex-wrap items-center gap-4"
          style="animation-delay: 250ms"
        >
          <a
            href="/contact"
            class="inline-flex items-center gap-2.5 rounded-full bg-gold px-7 py-3.5 text-sm font-bold text-marine shadow-md transition hover:bg-gold/90"
          >
            Prendre rendez-vous
            <svg
              class="h-4 w-4"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2.2"
              aria-hidden="true"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M5 12h14M13 5l7 7-7 7"></path>
            </svg>
          </a>
          <a
            href="/produits"
            class="inline-flex items-center rounded-full border border-white/30 bg-white/5 px-7 py-3.5 text-sm font-semibold text-white backdrop-blur-sm transition hover:border-white/60 hover:bg-white/10"
          >
            Découvrir nos matelas
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Value Props -->
  <section class="bg-page py-16">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="grid gap-6 lg:grid-cols-3">
        {
          valueProps.map((prop, index) => (
            <div class="home-card">
              <p
                class={`text-xs uppercase tracking-[0.2em] ${valuePropAccents[index % valuePropAccents.length]}`}
              >
                {prop.eyebrow}
              </p>
              <h2 class="home-display mt-4 text-2xl text-gray-900">
                {prop.title}
              </h2>
              <p class="mt-4 text-sm text-gray-700">{prop.description}</p>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- Categories -->
  <section class="py-20">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="flex flex-wrap items-end justify-between gap-6">
        <div>
          <p class="text-xs uppercase tracking-[0.3em] text-gray-400">
            Univers literie
          </p>
          <h2 class="home-display mt-4 text-3xl text-gray-900 sm:text-4xl">
            Composez votre confort.
          </h2>
        </div>
        <a href="/produits" class="text-sm font-semibold text-marine"
          >Voir toutes les collections</a
        >
      </div>
      <div class="mt-12 grid gap-6 md:grid-cols-2 lg:grid-cols-4">
        {
          categoriesToShow.map((category, index) => {
            const theme = categoryThemes[index % categoryThemes.length];
            return (
              <a
                href={category.href || "/produits"}
                class={`group relative overflow-hidden rounded-3xl border border-gray-200 bg-white p-6 shadow-lg transition hover:-translate-y-1 ${theme.badge}`}
              >
                <div
                  class={`absolute -right-8 -top-8 h-28 w-28 rounded-full bg-gradient-to-br ${theme.accent}`}
                />
                <div
                  class={`flex h-12 w-12 items-center justify-center rounded-2xl ${theme.iconBg} text-sm font-semibold text-gray-700`}
                >
                  {category.name?.slice(0, 2).toUpperCase()}
                </div>
                <h3 class="home-display mt-6 text-xl text-gray-900">
                  {category.name}
                </h3>
                <p class="mt-3 text-sm text-gray-700">
                  {category.description ||
                    "Sélection adaptée à votre confort et votre style."}
                </p>
                <span class="mt-6 inline-flex items-center gap-2 text-xs font-semibold uppercase tracking-[0.2em] text-gray-700">
                  Explorer
                  <svg
                    class="h-4 w-4"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                  >
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      d="M7 7h10v10"
                    />
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      d="M7 17L17 7"
                    />
                  </svg>
                </span>
              </a>
            );
          })
        }
      </div>
    </div>
  </section>

  <!-- Featured Products -->
  <section class="bg-page py-20">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="flex flex-wrap items-center justify-between gap-6">
        <div>
          <p class="text-xs uppercase tracking-[0.3em] text-gray-400">
            Sélection maison
          </p>
          <h2 class="home-display mt-4 text-3xl text-gray-900 sm:text-4xl">
            Produits en vedette.
          </h2>
          <p class="mt-4 max-w-2xl text-sm text-gray-700">
            Une sélection courte et efficace pour découvrir nos meilleures
            sensations, testées en magasin.
          </p>
        </div>
        <a href="/produits" class="text-sm font-semibold text-marine"
          >Voir tous les produits</a
        >
      </div>

      <div class="mt-12 grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-4">
        {
          featuredProducts.length > 0 ? (
            featuredProducts.map((product) => <ProductCard {...product} />)
          ) : (
            <div class="col-span-full rounded-3xl border border-dashed border-gray-200 bg-white p-10 text-center">
              <p class="text-base font-semibold text-gray-700">
                Aucun produit en vedette pour le moment.
              </p>
              <p class="mt-2 text-sm text-gray-500">
                Ajoutez des produits via Directus pour enrichir la vitrine.
              </p>
            </div>
          )
        }
      </div>
    </div>
  </section>

  <!-- Method -->
  <section class="py-20">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 gap-12 lg:grid-cols-[minmax(0,0.9fr)_minmax(0,1.1fr)]">
        <div>
          <p class="text-xs uppercase tracking-[0.3em] text-gray-400">
            Notre méthode
          </p>
          <h2 class="home-display mt-4 text-3xl text-gray-900 sm:text-4xl">
            {method.title}
          </h2>
          <p class="mt-4 text-sm text-gray-700">
            {method.intro}
          </p>
          <a
            href="/magasins"
            class="mt-8 inline-flex items-center gap-3 rounded-full bg-marine px-6 py-3 text-sm font-semibold text-white shadow-lg shadow-blue-900/20"
          >
            Visiter nos magasins
            <svg
              class="h-4 w-4"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
            >
              <path stroke-linecap="round" stroke-linejoin="round" d="M5 12h14"
              ></path>
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M13 5l7 7-7 7"></path>
            </svg>
          </a>
        </div>
        <div class="space-y-6">
          {
            method.steps.map((step, index) => (
              <div class="rounded-3xl border border-gray-200 bg-white p-6 shadow-md">
                <div class="flex items-center gap-4">
                  <div class="home-display flex h-12 w-12 items-center justify-center rounded-2xl bg-gray-900 text-lg text-white">
                    {String(index + 1).padStart(2, "0")}
                  </div>
                  <div>
                    <h3 class="home-display text-xl text-gray-900">
                      {step.title}
                    </h3>
                    <p class="mt-2 text-sm text-gray-700">
                      {step.description}
                    </p>
                  </div>
                </div>
              </div>
            ))
          }
        </div>
      </div>
    </div>
  </section>

  <!-- Stores -->
  <section class="bg-marine py-20 text-white">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="flex flex-wrap items-center justify-between gap-6">
        <div>
          <p class="text-xs uppercase tracking-[0.3em] text-white/60">
            Nos magasins
          </p>
          <h2 class="home-display mt-4 text-3xl sm:text-4xl">
            Venez tester le confort en magasin.
          </h2>
        </div>
        <a href="/magasins" class="text-sm font-semibold text-white"
          >Voir les horaires</a
        >
      </div>
      <div class="mt-12 grid gap-6 max-w-2xl mx-auto">
        {
          storeCards.map((store) => (
            <div class="overflow-hidden rounded-3xl bg-white/10">
              <img
                src={store.image}
                alt={`Magasin de ${store.name}`}
                class="h-64 w-full object-cover"
                width="1600"
                height="1066"
                loading="lazy"
                decoding="async"
              />
              <div class="p-6">
                <h3 class="home-display text-2xl">{store.name}</h3>
                <p class="mt-3 text-sm text-white/80">{store.description}</p>
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- Testimonials + Brands -->
  <section class="bg-page py-20">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 gap-10 lg:grid-cols-[minmax(0,1.1fr)_minmax(0,0.9fr)]">
        <div>
          <p class="text-xs uppercase tracking-[0.3em] text-gray-400">
            Avis clients
          </p>
          <h2 class="home-display mt-4 text-3xl text-gray-900 sm:text-4xl">
            Ils parlent de leur sommeil.
          </h2>
          <div class="mt-8 grid gap-6">
            {
              testimonials.map((testimonial) => (
                <div class="rounded-3xl border border-gray-200 bg-white p-6 shadow-sm">
                  <p class="text-sm text-gray-700">"{testimonial.quote}"</p>
                  <p class="mt-4 text-xs font-semibold uppercase tracking-[0.2em] text-gray-500">
                    {testimonial.name}
                    {testimonial.city && ` · ${testimonial.city}`}
                  </p>
                </div>
              ))
            }
          </div>
        </div>
        <div>
          <p class="text-xs uppercase tracking-[0.3em] text-gray-400">
            Marques partenaires
          </p>
          <h2 class="home-display mt-4 text-2xl text-gray-900">
            Les signatures que nous aimons.
          </h2>
          <p class="mt-4 text-sm text-gray-700">
            Des marques sélectionnées pour leur fiabilité, leur confort et leur
            qualité de fabrication.
          </p>
          <div class="mt-8 grid grid-cols-2 gap-4">
            {
              featuredBrands.length > 0 ? (
                featuredBrands.map((brand) => (
                  <div class="flex items-center justify-center rounded-2xl border border-gray-200 bg-white px-4 py-3 text-sm font-semibold text-gray-700">
                    {brand.logo ? (
                      <img
                        src={brand.logo}
                        alt={brand.name}
                        class="h-10 w-full object-contain"
                        loading="lazy"
                        decoding="async"
                      />
                    ) : (
                      brand.name
                    )}
                  </div>
                ))
              ) : (
                <div class="col-span-2 rounded-2xl border border-dashed border-gray-200 bg-white px-6 py-8 text-center text-sm text-gray-500">
                  Ajoutez vos marques dans Directus pour les mettre en avant.
                </div>
              )
            }
          </div>
          <a
            href="/produits"
            class="mt-8 inline-flex items-center gap-2 text-sm font-semibold text-marine"
          >
            Découvrir les produits
            <svg
              class="h-4 w-4"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
            >
              <path stroke-linecap="round" stroke-linejoin="round" d="M5 12h14"
              ></path>
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M13 5l7 7-7 7"></path>
            </svg>
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Final CTA -->
  <section class="py-20">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div
        class="home-sheen rounded-[36px] border border-gray-200 bg-white p-10 shadow-xl sm:p-14"
      >
        <div
          class="flex flex-col gap-8 lg:flex-row lg:items-center lg:justify-between"
        >
          <div>
            <p class="text-xs uppercase tracking-[0.3em] text-gray-400">
              Passez à l'action
            </p>
            <h2 class="home-display mt-4 text-3xl text-gray-900 sm:text-4xl">
              {cta.title}
            </h2>
            <p class="mt-4 max-w-xl text-sm text-gray-700">
              {cta.text}
            </p>
          </div>
          <div class="flex flex-wrap gap-4">
            <a
              href="/magasins"
              class="rounded-full bg-marine px-7 py-3 text-sm font-semibold text-white shadow-lg shadow-blue-900/20"
            >
              Trouver un magasin
            </a>
            <a
              href="/contact"
              class="rounded-full border border-gray-200 px-7 py-3 text-sm font-semibold text-gray-700"
            >
              Nous écrire
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>

<style>
  .hero-accent {
    color: var(--color-gold);
    padding-bottom: 0.14em;
    background-image: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 120 12' preserveAspectRatio='none'><path d='M4 9C32 3.5 88 3 116 6.5' fill='none' stroke='%23FFD24D' stroke-opacity='0.5' stroke-width='4' stroke-linecap='round'/></svg>");
    background-repeat: no-repeat;
    background-position: center bottom;
    background-size: 100% 0.14em;
  }

  @keyframes hero-rise {
    from {
      opacity: 0;
      translate: 0 20px;
    }
    to {
      opacity: 1;
      translate: 0 0;
    }
  }

  .hero-rise {
    animation: hero-rise 0.85s cubic-bezier(0.22, 1, 0.36, 1) both;
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-rise {
      animation: none;
    }
  }

  .home-card {
    border-radius: 24px;
    border: 1px solid var(--color-gray-200);
    background: linear-gradient(
      135deg,
      var(--color-white),
      var(--color-page)
    );
    padding: 28px;
    box-shadow: var(--shadow-lg);
  }
</style>
