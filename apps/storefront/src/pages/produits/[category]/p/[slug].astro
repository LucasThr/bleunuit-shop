---
import Layout from '../../../../layouts/Layout.astro';
import ProductCard from '../../../../components/ProductCard.astro';
import JsonLd from '../../../../components/JsonLd.astro';
import Breadcrumb from '../../../../components/Breadcrumb.astro';
import { getProductBySlug, getProductsByCategory } from '../../../../utils/catalog-client';
import { saleMode } from '../../../../utils/sale-mode';
import { mapProductToCard, productImageUrl as buildImageUrl } from '../../../../utils/product-card';
import { slugFor } from '../../../../utils/slugs';
import { sanitizeHtml } from '../../../../utils/sanitize';
import AddToCartButton from '../../../../components/cart/AddToCartButton.tsx';
import QuoteRequestForm from '../../../../components/QuoteRequestForm.tsx';

const { category, slug } = Astro.params;

// Get the product from Medusa
const product = await getProductBySlug(slug!);

if (!product) {
  return Astro.rewrite('/404');
}

// The query fetches category.* so this is always the full object
const productCategory = typeof product.category === 'object' ? product.category : null;
const categoryName = productCategory?.name || 'Produits';
const categorySlug = productCategory ? slugFor(productCategory) : 'produits';

// Wrong or legacy (name-based) category segment: 301 to the canonical URL
if (category !== categorySlug) {
  return Astro.redirect(`/produits/${categorySlug}/p/${slug}`, 301);
}

// Parse product prices
const productPrice = parseFloat(product.price) || 0;
const productPromoPrice = product.promo_price ? parseFloat(product.promo_price) : null;
const hasPromo = productPromoPrice && productPromoPrice < productPrice && productPrice > 0;
const discount = hasPromo ? Math.round(((productPrice - productPromoPrice!) / productPrice) * 100) : 0;

// The single owner of the cart-vs-devis decision: sale channel, stock, and
// variant all fold into this verdict.
const sale = saleMode(product);

// Construct product image URL
const productImageUrl = buildImageUrl(product.featured_image, 1200, 900, 85);

// Gallery entries are full image URLs.
const galleryUrls = product.gallery ?? [];

// Get related products from same category
const categoryId = productCategory?.id ?? String(product.category);
const allProducts = await getProductsByCategory(categoryId);
const relatedProducts = allProducts
  .filter(p => p.slug !== slug)
  .slice(0, 3)
  .map(mapProductToCard);

const brandName = typeof product.brand === 'object' ? product.brand?.name : product.brand;
const canonicalUrl = new URL(Astro.url.pathname, Astro.site).href;
const plainDescription = (product.description || '')
  .replace(/<[^>]*>/g, ' ')
  .replace(/\s+/g, ' ')
  .trim();
// Prefer the product's own copy for the SERP snippet; fall back to a
// name / brand / price line when the product has no description.
const metaDescription = plainDescription
  ? plainDescription.length > 155
    ? `${plainDescription.slice(0, 152).trimEnd()}…`
    : plainDescription
  : `${product.name}${brandName ? ` - ${brandName}` : ''}${productPrice > 0 ? ` - À partir de ${productPrice.toLocaleString('fr-FR')}€` : ''}`;
// Future validity date keeps the Offer from being flagged as expired.
const priceValidUntil = `${new Date().getFullYear() + 1}-12-31`;

const productJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Product',
  name: product.name,
  ...(productImageUrl && { image: [productImageUrl] }),
  ...(plainDescription && { description: plainDescription }),
  ...(brandName && { brand: { '@type': 'Brand', name: brandName } }),
  // Only online/both products advertise a purchasable Offer; an in-store-only
  // product isn't buyable online, so it gets no Offer.
  ...(sale.online && productPrice > 0 && {
    offers: {
      '@type': 'Offer',
      url: canonicalUrl,
      priceCurrency: 'EUR',
      price: (hasPromo ? productPromoPrice! : productPrice).toFixed(2),
      priceValidUntil,
      itemCondition: 'https://schema.org/NewCondition',
      availability: product.in_stock
        ? 'https://schema.org/InStock'
        : 'https://schema.org/OutOfStock',
      seller: { '@type': 'Organization', name: 'Literie Bleunuit' },
    },
  }),
};

const breadcrumbJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Accueil', item: new URL('/', Astro.site).href },
    { '@type': 'ListItem', position: 2, name: 'Produits', item: new URL('/produits', Astro.site).href },
    { '@type': 'ListItem', position: 3, name: categoryName, item: new URL(`/produits/${categorySlug}`, Astro.site).href },
    { '@type': 'ListItem', position: 4, name: product.name },
  ],
};
---

<Layout
  title={product.name}
  description={metaDescription}
  type="product"
  image={productImageUrl || undefined}
>
  <JsonLd data={productJsonLd} />
  <JsonLd data={breadcrumbJsonLd} />
  <!-- Breadcrumb -->
  <div class="border-b border-gray-200 bg-white">
    <div class="mx-auto max-w-7xl px-4 py-3.5 sm:px-6 lg:px-8">
      <Breadcrumb
        items={[
          { name: 'Accueil', href: '/' },
          { name: 'Produits', href: '/produits' },
          { name: categoryName, href: `/produits/${categorySlug}` },
          { name: product.name },
        ]}
      />
    </div>
  </div>

  <!-- Product Detail -->
  <section class="py-12">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 gap-12 lg:grid-cols-2">
        <!-- Image Gallery -->
        <div>
          <div class="aspect-[4/3] overflow-hidden rounded-2xl bg-gray-100 mb-4">
            <img
              src={productImageUrl || `https://placehold.co/1200x900/e5e7eb/6b7280?text=${encodeURIComponent(product.name || 'Product')}`}
              alt={product.name}
              class="h-full w-full object-cover object-center"
              width="1200"
              height="900"
              fetchpriority="high"
              decoding="async"
            />
          </div>

          {galleryUrls.length > 0 && (
            <div class="grid grid-cols-4 gap-4">
              {galleryUrls.map((imageUrl) => (
                <div class="aspect-square overflow-hidden rounded-xl bg-gray-100 cursor-pointer hover:opacity-75 transition">
                  <img
                    src={imageUrl}
                    alt={product.name}
                    class="h-full w-full object-cover object-center"
                    width="300"
                    height="300"
                    loading="lazy"
                    decoding="async"
                  />
                </div>
              ))}
            </div>
          )}
        </div>

        <!-- Product Info -->
        <div>
          {(typeof product.brand === 'object' ? product.brand?.name : product.brand) && (
            <p class="text-sm text-gray-500 mb-2">{typeof product.brand === 'object' ? product.brand?.name : product.brand}</p>
          )}
          <h1 class="text-h1 text-marine mb-4">
            {product.name}
          </h1>

          {/* Promo badge */}
          {hasPromo && (
            <div class="inline-block rounded-full bg-promo px-4 py-1 text-sm font-bold text-white mb-4">
              -{discount}% de réduction
            </div>
          )}

          {/* Price */}
          {productPrice > 0 && (
            <div class="mb-8">
              {hasPromo ? (
                <div>
                  <div class="flex items-baseline gap-3">
                    <span class="text-4xl font-bold text-promo">
                      {productPromoPrice?.toLocaleString('fr-FR')}€
                    </span>
                    <span class="text-xl text-gray-500 line-through">
                      {productPrice.toLocaleString('fr-FR')}€
                    </span>
                  </div>
                  <p class="mt-2 text-sm text-promo font-medium">
                    Économisez {(productPrice - productPromoPrice!).toLocaleString('fr-FR')}€
                  </p>
                </div>
              ) : (
                <span class="text-4xl font-bold text-gray-900">
                  {productPrice.toLocaleString('fr-FR')}€
                </span>
              )}
            </div>
          )}

          {/* Stock status */}
          <div class="mb-6">
            {product.in_stock ? (
              <div class="flex items-center text-success">
                <svg class="h-5 w-5 mr-2" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
                </svg>
                <span class="font-medium">En stock</span>
              </div>
            ) : (
              <div class="flex items-center text-danger">
                <svg class="h-5 w-5 mr-2" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd" />
                </svg>
                <span class="font-medium">Actuellement indisponible</span>
              </div>
            )}
          </div>

          {/* CTA Buttons — one primary money action (cart online + in stock, or
              a devis for in-store), a tonal "essayer en magasin" secondary that
              is always offered, and a quiet devis text link when a product is
              sold both ways. An out-of-stock online product gets a disabled
              primary in its place. */}
          <div class="mb-8 flex flex-col gap-3">
            {sale.canCheckout && (
              <AddToCartButton
                client:visible
                variantId={product.variantId!}
                size="block"
              />
            )}
            {sale.online && !sale.canCheckout && !product.in_stock && (
              <button
                type="button"
                disabled
                class="btn-primary flex w-full items-center justify-center gap-2 rounded-xl px-8 py-4 text-base font-semibold"
              >
                <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
                  <circle cx="12" cy="12" r="9" /><path stroke-linecap="round" d="M5.6 5.6l12.8 12.8" />
                </svg>
                Rupture de stock
              </button>
            )}
            {/* In-store-only: the devis IS the primary action, so it leads. */}
            {sale.inStore && !sale.canCheckout && (
              <QuoteRequestForm
                client:visible
                productId={product.id}
                productTitle={product.name}
                variant="primary"
              />
            )}
            <a
              href="/contact"
              class="btn-tonal flex w-full items-center justify-center gap-2 rounded-xl px-8 py-4 text-base font-semibold"
            >
              <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 21s7-5.6 7-11a7 7 0 1 0-14 0c0 5.4 7 11 7 11Z" /><circle cx="12" cy="10" r="2.4" />
              </svg>
              Nous contacter
            </a>
            {/* Sold both ways: the devis is a low-intent extra, so it trails as a
                quiet link below the two buttons. */}
            {sale.inStore && sale.canCheckout && (
              <QuoteRequestForm
                client:visible
                productId={product.id}
                productTitle={product.name}
                variant="secondary"
              />
            )}
          </div>

          {/* Features */}
          <div class="border-t border-gray-200 pt-6">
            <h3 class="text-h3 text-marine mb-4">Services inclus</h3>
            <ul class="space-y-3">
              <li class="flex items-start">
                <svg class="h-6 w-6 text-success mr-3 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                </svg>
                <span class="text-gray-700">Livraison et installation à domicile</span>
              </li>
              <li class="flex items-start">
                <svg class="h-6 w-6 text-success mr-3 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                </svg>
                <span class="text-gray-700">Reprise de votre ancienne literie</span>
              </li>
              <li class="flex items-start">
                <svg class="h-6 w-6 text-success mr-3 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                </svg>
                <span class="text-gray-700">Conseils personnalisés par nos experts</span>
              </li>
              <li class="flex items-start">
                <svg class="h-6 w-6 text-success mr-3 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                </svg>
                <span class="text-gray-700">Financement possible en 4, 6 ou 10 fois</span>
              </li>
            </ul>
          </div>
        </div>
      </div>

      {/* Product Description */}
      <div class="mt-16 border-t border-gray-200 pt-12">
        <h2 class="text-h2 text-marine mb-6">Description du produit</h2>
        <div class="prose prose-lg prose-blue max-w-none" set:html={sanitizeHtml(product.description || '')} />
      </div>
    </div>
  </section>

  {/* Related Products */}
  {relatedProducts.length > 0 && (
    <section class="bg-page py-16">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <h2 class="text-h2 text-marine mb-8">Produits similaires</h2>
        <div class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3">
          {relatedProducts.map((relatedProduct) => (
            <ProductCard {...relatedProduct} />
          ))}
        </div>
      </div>
    </section>
  )}

  {/* CTA Section */}
  <section class="bg-marine text-white py-12">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-h2 text-white mb-4">
        Besoin de conseils ?
      </h2>
      <p class="text-lg text-blue-100 mb-6">
        Nos experts sont à votre disposition pour vous aider à faire le bon choix
      </p>
      <div class="flex flex-col gap-4 sm:flex-row sm:justify-center">
        <a
          href="/contact"
          class="inline-flex items-center justify-center rounded-full bg-white px-8 py-3 text-base font-semibold text-marine hover:bg-blue-100 transition-colors"
        >
          Nous contacter
        </a>
      </div>
    </div>
  </section>
</Layout>
