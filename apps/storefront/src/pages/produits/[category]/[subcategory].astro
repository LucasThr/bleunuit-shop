---
import Layout from '../../../layouts/Layout.astro';
import ProductCard from '../../../components/ProductCard.astro';
import JsonLd from '../../../components/JsonLd.astro';
import { getCategoryBySlug, getSubcategoryBySlug, getProductsBySubcategory } from '../../../utils/catalog-client';
import { mapProductToCard } from '../../../utils/product-card';
import { slugFor } from '../../../utils/slugs';

const { category, subcategory } = Astro.params;

// Get the current category and subcategory from Medusa
const currentCategory = await getCategoryBySlug(category!);
const currentSubcategory = await getSubcategoryBySlug(subcategory!);

if (!currentCategory || !currentSubcategory) {
  return Astro.rewrite('/404');
}

// Verify subcategory belongs to category
const subcatCategoryId = typeof currentSubcategory.category === 'object'
  ? currentSubcategory.category.id
  : currentSubcategory.category;

if (subcatCategoryId !== currentCategory.id) {
  return Astro.rewrite('/404');
}

// Legacy name-based URLs permanently redirect to the canonical slug URL.
const categorySlug = slugFor(currentCategory);
const subcategorySlug = slugFor(currentSubcategory);
if (category !== categorySlug || subcategory !== subcategorySlug) {
  return Astro.redirect(`/produits/${categorySlug}/${subcategorySlug}`, 301);
}

// Get products filtered by subcategory
const allProducts = await getProductsBySubcategory(currentSubcategory.id);
const products = allProducts.map(mapProductToCard);

// Get unique brands from filtered products
const brandsSet = new Set(products.map(p => p.brand).filter(Boolean));
const brands = Array.from(brandsSet);

const breadcrumbJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Accueil', item: new URL('/', Astro.site).href },
    { '@type': 'ListItem', position: 2, name: 'Produits', item: new URL('/produits', Astro.site).href },
    { '@type': 'ListItem', position: 3, name: currentCategory.name, item: new URL(`/produits/${categorySlug}`, Astro.site).href },
    { '@type': 'ListItem', position: 4, name: currentSubcategory.name },
  ],
};

const metaDescription =
  currentSubcategory.description ||
  `${currentSubcategory.name} — notre sélection de ${currentCategory.name.toLowerCase()} chez Literie Bleunuit à Bruay-la-Buissière : conseils d'experts et essai en magasin.`;
---

<Layout title={`${currentSubcategory.name} - ${currentCategory.name}`} description={metaDescription}>
  <JsonLd data={breadcrumbJsonLd} />
  <!-- Header -->
  <section class="relative isolate overflow-hidden bg-marine py-16 text-white sm:py-20">
    <div
      class="pointer-events-none absolute -right-24 -top-24 h-80 w-80 rounded-full bg-gold/20 blur-3xl"
      aria-hidden="true"
    >
    </div>
    <div
      class="pointer-events-none absolute -bottom-32 left-1/4 h-72 w-72 rounded-full bg-blue-400/10 blur-3xl"
      aria-hidden="true"
    >
    </div>
    <div class="relative mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <nav class="mb-4 text-sm text-blue-100">
        <a href="/" class="hover:text-white">Accueil</a>
        <span class="mx-2">/</span>
        <a href="/produits" class="hover:text-white">Produits</a>
        <span class="mx-2">/</span>
        <a href={`/produits/${category}`} class="hover:text-white">{currentCategory.name}</a>
        <span class="mx-2">/</span>
        <span class="text-white">{currentSubcategory.name}</span>
      </nav>
      <h1 class="text-display flex items-center gap-3">
        {currentCategory.icon && <span class="text-5xl">{currentCategory.icon}</span>}
        {currentSubcategory.name}
      </h1>
      {currentSubcategory.description && (
        <p class="mt-4 max-w-3xl text-lg leading-relaxed text-white/75">
          {currentSubcategory.description}
        </p>
      )}
    </div>
  </section>

  <!-- Filters and Products -->
  <section class="py-12">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <!-- Filter Bar -->
      <div class="mb-8 flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
        <p class="text-gray-700">
          <span class="font-semibold text-gray-900">{products.length}</span> produit{products.length > 1 ? 's' : ''} trouvé{products.length > 1 ? 's' : ''}
        </p>
        {brands.length > 0 && (
          <div class="flex gap-4">
            <select class="rounded-xl border-gray-200 py-2 pl-3 pr-10 text-sm focus:border-marine focus:outline-none focus:ring-1 focus:ring-marine">
              <option>Toutes les marques</option>
              {brands.map((brand) => (
                <option>{brand}</option>
              ))}
            </select>
            <select class="rounded-xl border-gray-200 py-2 pl-3 pr-10 text-sm focus:border-marine focus:outline-none focus:ring-1 focus:ring-marine">
              <option>Trier par</option>
              <option>Prix croissant</option>
              <option>Prix décroissant</option>
              <option>Nouveautés</option>
              <option>Popularité</option>
            </select>
          </div>
        )}
      </div>

      <!-- Products Grid -->
      {products.length > 0 ? (
        <div class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3">
          {products.map((product) => (
            <ProductCard {...product} />
          ))}
        </div>
      ) : (
        <div class="rounded-3xl border border-dashed border-gray-200 bg-white p-10 text-center">
          <p class="text-base font-semibold text-gray-700">Aucun produit disponible dans cette sous-catégorie pour le moment.</p>
          <a
            href={`/produits/${category}`}
            class="mt-4 inline-block font-medium text-royal hover:text-marine"
          >
            Voir tous les produits de la catégorie {currentCategory.name}
          </a>
        </div>
      )}
    </div>
  </section>

  <!-- Advice Section -->
  <section class="bg-page py-12">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="rounded-3xl border border-gray-200 bg-white p-8 shadow-sm">
        <h2 class="text-h2 text-marine mb-4">
          Besoin de conseils ?
        </h2>
        <p class="text-gray-700 mb-6">
          Nos experts sont à votre disposition dans nos magasins pour vous aider à choisir la literie idéale selon vos besoins et votre morphologie.
        </p>
        <div class="flex flex-col gap-4 sm:flex-row">
          <a
            href="/contact"
            class="btn-primary inline-flex items-center justify-center rounded-full px-6 py-3 text-base font-semibold"
          >
            Nous contacter
          </a>
        </div>
      </div>
    </div>
  </section>
</Layout>
