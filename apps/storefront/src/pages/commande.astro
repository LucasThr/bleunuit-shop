---
import Layout from "../layouts/Layout.astro";
import CheckoutForm from "../components/cart/CheckoutForm.tsx";

export const prerender = false;
---

<Layout
  title="Commande"
  description="Finalisez votre commande Bleunuit."
  noindex={true}
>
  <section class="bg-marine py-12 text-white">
    <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
      <p class="text-xs uppercase tracking-[0.3em] text-gold">Paiement</p>
      <h1
        class="home-display mt-3 text-3xl sm:text-4xl"
      >
        Finaliser la commande
      </h1>
    </div>
  </section>

  <section class="py-12">
    <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
      <CheckoutForm client:only="react" />
    </div>
  </section>
</Layout>
