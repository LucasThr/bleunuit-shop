# Public URL of the website itself. Used for canonical URLs, Open Graph tags,
# sitemap.xml and robots.txt — set this to the production domain when deploying.
PUBLIC_SITE_URL=

# --- Medusa (commerce + CMS backend) ---
# The storefront reads all content and catalog data from Medusa.
PUBLIC_MEDUSA_URL=http://localhost:9000
PUBLIC_MEDUSA_PUBLISHABLE_KEY=
PUBLIC_MEDUSA_REGION_ID=
# Stripe publishable key for the checkout card form (optional).
# PUBLIC_STRIPE_PUBLISHABLE_KEY=

# --- Resend (contact form + newsletter emails) ---
# Server-side secret — set it in the deploy environment. Never prefix PUBLIC_.
RESEND_API_KEY=
# Where contact-form messages are delivered.
CONTACT_TO_EMAIL=contact@bleunuit.fr
# Verified Resend sender — the domain must be verified in your Resend account.
CONTACT_FROM_EMAIL=Literie Bleunuit <noreply@bleunuit.fr>
# Optional: Resend Audience id to add newsletter subscribers to. If unset,
# signups are emailed to CONTACT_TO_EMAIL instead.
RESEND_AUDIENCE_ID=
