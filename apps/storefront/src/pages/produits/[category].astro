---
import Layout from '../../layouts/Layout.astro';
import ProductCard from '../../components/ProductCard.astro';
import JsonLd from '../../components/JsonLd.astro';
import PageHero from '../../components/PageHero.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import { getCategoryBySlug, getSubcategoriesByCategory, getProductsByCategory } from '../../utils/catalog-client';
import { mapProductToCard } from '../../utils/product-card';
import { slugFor } from '../../utils/slugs';
import { resolveCategoryImage } from '../../utils/category-image';

const { category } = Astro.params;

// Get the current category from Medusa
const currentCategory = await getCategoryBySlug(category!);

if (!currentCategory) {
  return Astro.rewrite('/404');
}

// Legacy name-based URLs (e.g. /produits/Têtes de lit) permanently
// redirect to the canonical slug URL.
const categorySlug = slugFor(currentCategory);
if (category !== categorySlug) {
  return Astro.redirect(`/produits/${categorySlug}`, 301);
}

// Get subcategories and products for this category
const [categorySubcategories, allProducts] = await Promise.all([
  getSubcategoriesByCategory(currentCategory.id),
  getProductsByCategory(currentCategory.id),
]);

const products = allProducts.map(mapProductToCard);

// Get unique brands from filtered products
const brandsSet = new Set(products.map(p => p.brand).filter(Boolean));
const brands = Array.from(brandsSet);

const breadcrumbJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Accueil', item: new URL('/', Astro.site).href },
    { '@type': 'ListItem', position: 2, name: 'Produits', item: new URL('/produits', Astro.site).href },
    { '@type': 'ListItem', position: 3, name: currentCategory.name },
  ],
};

const metaDescription =
  currentCategory.description ||
  `Découvrez notre sélection de ${currentCategory.name.toLowerCase()} chez Literie Bleunuit : marques reconnues, conseils d'experts et essai en magasin à Bruay-la-Buissière.`;

const heroImage = resolveCategoryImage(currentCategory) || '/images/design/hero-bedroom.jpg';
---

<Layout title={currentCategory.name} description={metaDescription}>
  <JsonLd data={breadcrumbJsonLd} />
  <!-- Header -->
  <PageHero image={heroImage} imageAlt={`Catégorie ${currentCategory.name}`}>
    <Breadcrumb
      variant="dark"
      class="mb-6"
      items={[
        { name: 'Accueil', href: '/' },
        { name: 'Produits', href: '/produits' },
        { name: currentCategory.name },
      ]}
    />
    <h1 class="home-display text-display text-balance drop-shadow-[0_2px_18px_rgba(4,10,25,0.45)]">
      {currentCategory.name}
    </h1>
    {currentCategory.description && (
      <p class="mt-4 max-w-3xl text-lg leading-relaxed text-white/85 drop-shadow-[0_1px_10px_rgba(4,10,25,0.4)]">
        {currentCategory.description}
      </p>
    )}

    <!-- Subcategories -->
    {categorySubcategories.length > 0 && (
      <div class="mt-8 flex flex-wrap gap-2">
        {categorySubcategories.map((sub) => (
          <a
            href={`/produits/${categorySlug}/${slugFor(sub)}`}
            class="inline-flex items-center rounded-full border border-white/20 bg-white/10 px-4 py-2 text-sm font-medium text-white backdrop-blur-sm transition hover:border-white/40 hover:bg-white/20"
          >
            {sub.name}
          </a>
        ))}
      </div>
    )}
  </PageHero>

  <!-- Filters and Products -->
  <section class="py-12">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <!-- Filter Bar -->
      <div class="mb-8 flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
        <p class="text-gray-700">
          <span class="font-semibold text-gray-900">{products.length}</span> produits trouvés
        </p>
        <div class="flex gap-4">
          <select class="rounded-xl border-gray-200 py-2 pl-3 pr-10 text-sm focus:border-marine focus:outline-none focus:ring-1 focus:ring-marine">
            <option>Toutes les marques</option>
            <option>Dunlopillo</option>
            <option>Duvivier</option>
            <option>André Renault</option>
            <option>Simmons</option>
            <option>Technilat</option>
          </select>
          <select class="rounded-xl border-gray-200 py-2 pl-3 pr-10 text-sm focus:border-marine focus:outline-none focus:ring-1 focus:ring-marine">
            <option>Trier par</option>
            <option>Prix croissant</option>
            <option>Prix décroissant</option>
            <option>Nouveautés</option>
            <option>Popularité</option>
          </select>
        </div>
      </div>

      <!-- Products Grid -->
      <div class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {products.map((product) => (
          <ProductCard {...product} />
        ))}
      </div>
    </div>
  </section>

  <!-- Advice Section -->
  <section class="bg-page py-12">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="rounded-3xl border border-gray-200 bg-white p-8 shadow-sm">
        <h2 class="text-h2 text-marine mb-4">
          Besoin de conseils ?
        </h2>
        <p class="text-gray-700 mb-6">
          Nos experts sont à votre disposition dans nos magasins pour vous aider à choisir la literie idéale selon vos besoins et votre morphologie.
        </p>
        <div class="flex flex-col gap-4 sm:flex-row">
          <a
            href="/contact"
            class="btn-primary inline-flex items-center justify-center rounded-full px-6 py-3 text-base font-semibold"
          >
            Nous contacter
          </a>
        </div>
      </div>
    </div>
  </section>
</Layout>
