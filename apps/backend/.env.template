STORE_CORS=http://localhost:8000,https://docs.medusajs.com
ADMIN_CORS=http://localhost:5173,http://localhost:9000,https://docs.medusajs.com
AUTH_CORS=http://localhost:5173,http://localhost:9000,https://docs.medusajs.com
# When set, Redis backs the cache, event bus and workflow engine. Leave unset
# locally to use the in-memory defaults; set it in production (e.g. Upstash).
REDIS_URL=redis://localhost:6379
# Generate strong values with: openssl rand -base64 32
JWT_SECRET=__CHANGE_ME__
COOKIE_SECRET=__CHANGE_ME__
DATABASE_URL=
DB_NAME=medusa-backend
# Set DATABASE_SSL=true when the Postgres provider requires TLS (managed PG).
# DATABASE_SSL=true

# --- File storage (production) ---
# When S3_ENDPOINT is set, uploads go to S3-compatible object storage instead of
# the ephemeral local disk (e.g. Cloudflare R2). Leave them unset locally to keep
# the on-disk file provider.
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=
# S3_REGION=auto
# S3_ENDPOINT=https://<accountid>.r2.cloudflarestorage.com
# S3_BUCKET=
# Public base URL for stored files, e.g. https://pub-xxxx.r2.dev
# S3_FILE_URL=
