---
import Layout from '../layouts/Layout.astro';
import JsonLd from '../components/JsonLd.astro';
import { getContact, getAllStores } from '../utils/cms-client';

const [contact, stores] = await Promise.all([
  getContact().catch((err) => {
    console.error('contact: failed to load contact content', err);
    return null;
  }),
  getAllStores().catch(() => []),
]);

// Editable contact details, with fallbacks to the previous static values.
const storeName = contact?.store_name || 'Bruay-la-Buissière';
const addressLines = (
  contact?.address || 'Centre Commercial Auchan\n62700 Bruay-la-Buissière'
)
  .split('\n')
  .map((line) => line.trim())
  .filter(Boolean);
const phone = contact?.phone || '03 21 53 21 45';
const phoneHref = phone.replace(/\s+/g, '');
const email = contact?.email || 'contact@bleunuit.fr';
const hours = contact?.hours?.length
  ? contact.hours
  : [
      { label: 'Lundi - Vendredi', value: '9h30 - 12h30 / 14h - 19h' },
      { label: 'Samedi', value: '9h30 - 19h' },
      { label: 'Dimanche', value: 'Fermé' },
    ];

// The per-location FurnitureStore schema now lives here (the /magasins page is
// retired). Sourced from the cms store record for the discrete address/geo
// fields the schema needs; the openingHoursSpecification mirrors the default
// schedule shown above.
const pageUrl = new URL('/contact', Astro.site).href;
const storeJsonLd = stores.map((store) => ({
  '@context': 'https://schema.org',
  '@type': 'FurnitureStore',
  name: `Literie Bleunuit ${store.city}`,
  url: pageUrl,
  telephone: store.phone,
  email: store.email,
  address: {
    '@type': 'PostalAddress',
    streetAddress: store.address,
    addressLocality: store.city,
    postalCode: store.postal_code,
    addressCountry: 'FR',
  },
  ...(store.latitude != null && store.longitude != null && {
    geo: {
      '@type': 'GeoCoordinates',
      latitude: store.latitude,
      longitude: store.longitude,
    },
  }),
  openingHoursSpecification: [
    {
      '@type': 'OpeningHoursSpecification',
      dayOfWeek: ['Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday'],
      opens: '09:30',
      closes: '12:30',
    },
    {
      '@type': 'OpeningHoursSpecification',
      dayOfWeek: ['Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday'],
      opens: '14:00',
      closes: '19:00',
    },
    {
      '@type': 'OpeningHoursSpecification',
      dayOfWeek: ['Saturday'],
      opens: '09:30',
      closes: '19:00',
    },
  ],
}));
---

<Layout title="Contact" description="Contactez Literie Bleunuit pour toutes vos questions sur nos produits et services.">
  {storeJsonLd.map((data) => <JsonLd data={data} />)}
  <!-- Header -->
  <section class="bg-gradient-to-r from-blue-900 to-royal py-16 text-white">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <h1 class="text-4xl font-bold tracking-tight sm:text-5xl">
        Nous Contacter
      </h1>
      <p class="mt-4 text-xl text-blue-100">
        Une question ? Notre équipe est là pour vous répondre
      </p>
    </div>
  </section>

  <!-- Contact Form -->
  <section class="py-16">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 gap-12 lg:grid-cols-2">
        <!-- Form -->
        <div>
          <h2 class="text-2xl font-bold text-gray-900 mb-6">
            Envoyez-nous un message
          </h2>
          <form id="contact-form" method="POST" action="/api/contact" class="space-y-6">
            <div class="hidden" aria-hidden="true">
              <label>Ne pas remplir<input type="text" name="company" tabindex="-1" autocomplete="off" /></label>
            </div>
            <div class="grid grid-cols-1 gap-6 sm:grid-cols-2">
              <div>
                <label for="firstName" class="block text-sm font-medium text-gray-700 mb-2">
                  Prénom
                </label>
                <input
                  type="text"
                  id="firstName"
                  name="firstName"
                  class="w-full rounded-md border border-gray-200 px-4 py-3 focus:border-blue-500 focus:outline-none focus:ring-1 focus:ring-blue-500"
                  required
                />
              </div>
              <div>
                <label for="lastName" class="block text-sm font-medium text-gray-700 mb-2">
                  Nom
                </label>
                <input
                  type="text"
                  id="lastName"
                  name="lastName"
                  class="w-full rounded-md border border-gray-200 px-4 py-3 focus:border-blue-500 focus:outline-none focus:ring-1 focus:ring-blue-500"
                  required
                />
              </div>
            </div>

            <div>
              <label for="email" class="block text-sm font-medium text-gray-700 mb-2">
                Email
              </label>
              <input
                type="email"
                id="email"
                name="email"
                class="w-full rounded-md border border-gray-200 px-4 py-3 focus:border-blue-500 focus:outline-none focus:ring-1 focus:ring-blue-500"
                required
              />
            </div>

            <div>
              <label for="phone" class="block text-sm font-medium text-gray-700 mb-2">
                Téléphone
              </label>
              <input
                type="tel"
                id="phone"
                name="phone"
                class="w-full rounded-md border border-gray-200 px-4 py-3 focus:border-blue-500 focus:outline-none focus:ring-1 focus:ring-blue-500"
              />
            </div>

            <div>
              <label for="store" class="block text-sm font-medium text-gray-700 mb-2">
                Magasin concerné
              </label>
              <select
                id="store"
                name="store"
                class="w-full rounded-md border border-gray-200 px-4 py-3 focus:border-blue-500 focus:outline-none focus:ring-1 focus:ring-blue-500"
              >
                <option value="">Sélectionnez un magasin</option>
                <option value="bruay">{storeName}</option>
              </select>
            </div>

            <div>
              <label for="subject" class="block text-sm font-medium text-gray-700 mb-2">
                Sujet
              </label>
              <input
                type="text"
                id="subject"
                name="subject"
                class="w-full rounded-md border border-gray-200 px-4 py-3 focus:border-blue-500 focus:outline-none focus:ring-1 focus:ring-blue-500"
                required
              />
            </div>

            <div>
              <label for="message" class="block text-sm font-medium text-gray-700 mb-2">
                Message
              </label>
              <textarea
                id="message"
                name="message"
                rows="6"
                class="w-full rounded-md border border-gray-200 px-4 py-3 focus:border-blue-500 focus:outline-none focus:ring-1 focus:ring-blue-500"
                required
              ></textarea>
            </div>

            <button
              type="submit"
              class="w-full rounded-md bg-blue-600 px-8 py-3 text-base font-semibold text-white hover:bg-marine transition-colors"
            >
              Envoyer le message
            </button>
            <p id="contact-status" class="text-sm text-danger" role="alert" aria-live="polite"></p>
          </form>
          <div
            id="contact-success"
            class="hidden rounded-lg border border-success bg-success-bg p-6 text-success"
          >
            <p class="font-semibold">Merci, votre message a bien été envoyé.</p>
            <p class="mt-1 text-sm">Notre équipe vous répondra dans les meilleurs délais.</p>
          </div>
        </div>

        <!-- Contact Info -->
        <div>
          <h2 class="text-2xl font-bold text-gray-900 mb-6">
            Nos coordonnées
          </h2>

          <div class="space-y-8">
            <!-- Bruay Store -->
            <div class="rounded-lg border border-gray-200 bg-page p-6">
              <h3 class="text-lg font-semibold text-gray-900 mb-4">
                {storeName}
              </h3>
              <div class="space-y-3 text-gray-700">
                <div class="flex items-start">
                  <svg class="h-5 w-5 mr-3 mt-1 flex-shrink-0 text-blue-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                  </svg>
                  <div>
                    {addressLines.map((line) => <p>{line}</p>)}
                  </div>
                </div>
                <div class="flex items-center">
                  <svg class="h-5 w-5 mr-3 flex-shrink-0 text-blue-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
                  </svg>
                  <a href={`tel:${phoneHref}`} class="text-blue-600 hover:text-marine">
                    {phone}
                  </a>
                </div>
              </div>
            </div>

            <!-- General Email -->
            <div class="flex items-center rounded-lg border border-gray-200 bg-page p-6">
              <svg class="h-5 w-5 mr-3 flex-shrink-0 text-blue-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
              </svg>
              <a href={`mailto:${email}`} class="text-blue-600 hover:text-marine">
                {email}
              </a>
            </div>
          </div>

          <!-- Opening Hours -->
          <div class="mt-8 rounded-lg border border-gray-200 bg-page p-6">
            <h3 class="text-lg font-semibold text-gray-900 mb-4">
              Horaires d'ouverture
            </h3>
            <div class="space-y-2 text-sm text-gray-700">
              {hours.map((row) => (
                <div class="flex justify-between">
                  <span class="font-medium">{row.label}</span>
                  <span>{row.value}</span>
                </div>
              ))}
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <script>
    const form = document.getElementById('contact-form') as HTMLFormElement | null;
    const status = document.getElementById('contact-status');
    const success = document.getElementById('contact-success');
    form?.addEventListener('submit', async (event) => {
      event.preventDefault();
      const button = form.querySelector('button[type="submit"]') as HTMLButtonElement | null;
      const label = button?.textContent;
      if (button) {
        button.disabled = true;
        button.textContent = 'Envoi…';
      }
      if (status) status.textContent = '';
      try {
        const response = await fetch('/api/contact', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(Object.fromEntries(new FormData(form))),
        });
        const result = await response.json().catch(() => ({}));
        if (response.ok) {
          form.classList.add('hidden');
          success?.classList.remove('hidden');
        } else if (status) {
          status.textContent = result.error || "L'envoi a échoué. Réessayez plus tard.";
        }
      } catch {
        if (status) status.textContent = "L'envoi a échoué. Vérifiez votre connexion.";
      } finally {
        if (button) {
          button.disabled = false;
          button.textContent = label ?? 'Envoyer le message';
        }
      }
    });
  </script>
</Layout>
