# Public URL of the website itself. Used for canonical URLs, Open Graph tags,
# sitemap.xml and robots.txt — set this to the production domain when deploying.
PUBLIC_SITE_URL=

# --- Medusa (commerce + CMS backend) ---
# The storefront reads all content and catalog data from Medusa.
PUBLIC_MEDUSA_URL=http://localhost:9000
PUBLIC_MEDUSA_PUBLISHABLE_KEY=
PUBLIC_MEDUSA_REGION_ID=
# Stripe publishable key for the checkout card form (optional).
# PUBLIC_STRIPE_PUBLISHABLE_KEY=
