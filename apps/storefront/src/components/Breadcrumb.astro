---
// Refined breadcrumb shared across product, category and article pages.
// `dark` sits on the photographic page heroes (white text); `light` sits on a
// white sub-bar (the product page). The last item is the current page and is
// rendered as plain text, never a link.
interface Crumb {
  name: string;
  href?: string;
}
interface Props {
  items: Crumb[];
  variant?: 'light' | 'dark';
  class?: string;
}
const { items, variant = 'light', class: className = '' } = Astro.props;
const isDark = variant === 'dark';

const linkClass = isDark
  ? 'text-white/70 transition-colors hover:text-white'
  : 'text-gray-500 transition-colors hover:text-royal';
const currentClass = isDark ? 'font-semibold text-white' : 'font-semibold text-marine';
const sepClass = isDark ? 'text-white/35' : 'text-gray-300';
---

<nav aria-label="Fil d'ariane" class={`text-sm ${className}`}>
  <ol class="flex flex-wrap items-center gap-x-1.5 gap-y-1">
    {
      items.map((item, index) => {
        const isLast = index === items.length - 1;
        return (
          <li class="flex items-center gap-x-1.5">
            {item.href && !isLast ? (
              <a href={item.href} class={linkClass}>
                {item.name}
              </a>
            ) : (
              <span class={currentClass} aria-current={isLast ? 'page' : undefined}>
                {item.name}
              </span>
            )}
            {!isLast && (
              <svg
                class={`h-3.5 w-3.5 shrink-0 ${sepClass}`}
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                aria-hidden="true"
              >
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
              </svg>
            )}
          </li>
        );
      })
    }
  </ol>
</nav>
