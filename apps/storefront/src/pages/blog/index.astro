---
import Layout from '../../layouts/Layout.astro';
import { getAllBlogPosts } from '../../utils/cms-client';

// Get blog posts from Medusa
const allPosts = await getAllBlogPosts();
const posts = allPosts.map(post => ({
  title: post.title,
  slug: post.slug,
  excerpt: post.excerpt,
  publishDate: post.publish_date,
  category: post.category,
  image: post.featured_image || null,
  author: post.author
}));

const categoryNames: Record<string, string> = {
  'sleep-tips': 'Conseils sommeil',
  'product-guides': 'Guides produits',
  'company-news': 'Actualités'
};

function formatDate(dateString: string) {
  const date = new Date(dateString);
  return date.toLocaleDateString('fr-FR', {
    year: 'numeric',
    month: 'long',
    day: 'numeric'
  });
}
---

<Layout title="Blog" description="Conseils et astuces pour améliorer votre sommeil. Découvrez nos guides sur la literie et le bien-être.">
  <!-- Header -->
  <section class="bg-gradient-to-r from-blue-900 to-royal py-16 text-white">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <h1 class="text-4xl font-bold tracking-tight sm:text-5xl">
        Notre Blog
      </h1>
      <p class="mt-4 text-xl text-blue-100">
        Conseils et astuces pour un sommeil de qualité
      </p>
    </div>
  </section>

  <!-- Categories Filter -->
  <section class="bg-page py-6">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="flex flex-wrap gap-3">
        <button class="rounded-full bg-blue-600 px-6 py-2 text-sm font-semibold text-white">
          Tous les articles
        </button>
        <button class="rounded-full bg-white px-6 py-2 text-sm font-semibold text-gray-700 hover:bg-gray-100 transition-colors">
          Conseils sommeil
        </button>
        <button class="rounded-full bg-white px-6 py-2 text-sm font-semibold text-gray-700 hover:bg-gray-100 transition-colors">
          Guides produits
        </button>
        <button class="rounded-full bg-white px-6 py-2 text-sm font-semibold text-gray-700 hover:bg-gray-100 transition-colors">
          Actualités
        </button>
      </div>
    </div>
  </section>

  <!-- Blog Posts -->
  <section class="py-12">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 gap-8 md:grid-cols-2 lg:grid-cols-3">
        {posts.map((post) => (
          <article class="group overflow-hidden rounded-lg border border-gray-200 bg-white shadow-sm transition-all hover:shadow-lg">
            <a href={`/blog/${post.slug}`} class="block">
              <!-- Image -->
              <div class="aspect-[16/9] overflow-hidden bg-gray-200">
                {post.image ? (
                  <img
                    src={post.image}
                    alt={post.title}
                    class="h-full w-full object-cover object-center"
                    width="1280"
                    height="720"
                    loading="lazy"
                    decoding="async"
                  />
                ) : (
                  <div class="flex h-full w-full items-center justify-center text-gray-400">
                    <svg class="h-16 w-16" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
                    </svg>
                  </div>
                )}
              </div>

              <!-- Content -->
              <div class="p-6">
                <div class="mb-3 flex items-center gap-3 text-sm text-gray-500">
                  <span class="inline-flex items-center rounded-full bg-blue-100 px-3 py-1 text-xs font-medium text-blue-800">
                    {categoryNames[post.category]}
                  </span>
                  <time datetime={post.publishDate}>{formatDate(post.publishDate)}</time>
                </div>

                <h2 class="mb-2 text-xl font-bold text-gray-900 line-clamp-2 group-hover:text-blue-600 transition-colors">
                  {post.title}
                </h2>

                <p class="mb-4 text-gray-700 line-clamp-3">
                  {post.excerpt}
                </p>

                <div class="flex items-center justify-between">
                  <span class="text-sm text-gray-500">{post.author}</span>
                  <span class="inline-flex items-center text-sm font-medium text-blue-600 group-hover:text-marine">
                    Lire la suite
                    <svg class="ml-1 h-4 w-4 transition-transform group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                    </svg>
                  </span>
                </div>
              </div>
            </a>
          </article>
        ))}
      </div>

    </div>
  </section>

  <!-- Newsletter CTA -->
  <section class="bg-blue-900 py-16 text-white">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="text-center">
        <h2 class="text-3xl font-bold tracking-tight sm:text-4xl">
          Restez informé
        </h2>
        <p class="mt-4 text-xl text-blue-100">
          Inscrivez-vous à notre newsletter pour recevoir nos derniers conseils
        </p>
        <form
          id="newsletter-form"
          method="POST"
          action="/api/newsletter"
          class="mt-8 flex flex-col gap-4 sm:flex-row sm:justify-center"
        >
          <div class="hidden" aria-hidden="true">
            <label>Ne pas remplir<input type="text" name="company" tabindex="-1" autocomplete="off" /></label>
          </div>
          <input
            type="email"
            name="email"
            required
            placeholder="Votre adresse email"
            class="rounded-md px-4 py-3 text-gray-900 placeholder:text-gray-500 focus:outline-none focus:ring-2 focus:ring-white sm:w-96"
          />
          <button
            type="submit"
            class="rounded-md bg-white px-8 py-3 font-semibold text-blue-900 hover:bg-blue-100 transition-colors"
          >
            S'inscrire
          </button>
        </form>
        <p id="newsletter-status" class="mt-4 text-sm text-blue-100" role="alert" aria-live="polite"></p>
      </div>
    </div>
  </section>

  <script>
    const form = document.getElementById('newsletter-form') as HTMLFormElement | null;
    const status = document.getElementById('newsletter-status');
    form?.addEventListener('submit', async (event) => {
      event.preventDefault();
      const button = form.querySelector('button[type="submit"]') as HTMLButtonElement | null;
      const label = button?.textContent;
      if (button) {
        button.disabled = true;
        button.textContent = 'Inscription…';
      }
      if (status) status.textContent = '';
      try {
        const response = await fetch('/api/newsletter', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(Object.fromEntries(new FormData(form))),
        });
        const result = await response.json().catch(() => ({}));
        if (response.ok) {
          form.classList.add('hidden');
          if (status) status.textContent = 'Merci, votre inscription est confirmée !';
        } else if (status) {
          status.textContent = result.error || "L'inscription a échoué. Réessayez plus tard.";
        }
      } catch {
        if (status) status.textContent = "L'inscription a échoué. Vérifiez votre connexion.";
      } finally {
        if (button) {
          button.disabled = false;
          button.textContent = label ?? "S'inscrire";
        }
      }
    });
  </script>
</Layout>
