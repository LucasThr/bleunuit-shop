---
import Layout from '../layouts/Layout.astro';
import JsonLd from '../components/JsonLd.astro';
import { getAllStores } from '../utils/cms-client';

// Get stores from Directus
const allStores = await getAllStores();
const stores = allStores.map(store => ({
  slug: store.slug,
  name: store.name,
  address: store.address,
  city: store.city,
  postalCode: store.postal_code,
  phone: store.phone,
  email: store.email,
  mapUrl: store.map_url,
  latitude: store.latitude,
  longitude: store.longitude,
  image: store.image || null,
}));

// Map store images
const storeImages: Record<string, string> = {
  'bruay-la-buissiere': '/images/stores/bruay-la-buissiere.png',
};

const pageUrl = new URL('/magasins', Astro.site).href;

// Hours mirror the schedule displayed below (Mon-Sat, closed Sunday)
const storesJsonLd = stores.map((store) => ({
  '@context': 'https://schema.org',
  '@type': 'FurnitureStore',
  name: `Literie Bleunuit ${store.city}`,
  url: pageUrl,
  telephone: store.phone,
  email: store.email,
  address: {
    '@type': 'PostalAddress',
    streetAddress: store.address,
    addressLocality: store.city,
    postalCode: store.postalCode,
    addressCountry: 'FR',
  },
  ...(store.latitude != null && store.longitude != null && {
    geo: {
      '@type': 'GeoCoordinates',
      latitude: store.latitude,
      longitude: store.longitude,
    },
  }),
  openingHoursSpecification: [
    {
      '@type': 'OpeningHoursSpecification',
      dayOfWeek: ['Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday', 'Saturday'],
      opens: '09:30',
      closes: '12:00',
    },
    {
      '@type': 'OpeningHoursSpecification',
      dayOfWeek: ['Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday', 'Saturday'],
      opens: '14:00',
      closes: '18:30',
    },
  ],
}));
---

<Layout title="Notre Magasin" description="Visitez notre magasin de literie à Bruay-la-Buissière. Conseils personnalisés et large choix de matelas, sommiers et accessoires.">
  {storesJsonLd.map((data) => <JsonLd data={data} />)}
  <!-- Header -->
  <section class="bg-gradient-to-r from-blue-900 to-blue-700 py-16 text-white">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <h1 class="text-4xl font-bold tracking-tight sm:text-5xl">
        Notre Magasin
      </h1>
      <p class="mt-4 text-xl text-blue-100 max-w-3xl">
        Visitez notre showroom à Bruay-la-Buissière pour découvrir notre gamme complète de literie et bénéficier des conseils de nos experts.
      </p>
    </div>
  </section>

  <!-- Stores Grid -->
  <section class="py-16">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 gap-12 max-w-2xl mx-auto">
        {stores.map((store) => {
          const storeSlug = store.slug.toLowerCase().replace(/\s+/g, '-');
          const storeImage = store.image || storeImages[storeSlug] || '/images/placeholder-store.jpg';

          return (
            <div class="bg-white rounded-lg shadow-lg overflow-hidden">
              <!-- Store Image -->
              <div class="aspect-[16/9] overflow-hidden bg-gray-100">
                <img
                  src={storeImage}
                  alt={`Magasin ${store.name}`}
                  class="w-full h-full object-cover"
                />
              </div>

              <!-- Store Info -->
              <div class="p-6">
                <h2 class="text-2xl font-bold text-gray-900 mb-4">
                  {store.name}
                </h2>

                <div class="space-y-3 text-gray-600">
                  <!-- Address -->
                  <div class="flex items-start gap-3">
                    <svg class="h-6 w-6 text-blue-600 flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                    </svg>
                    <div>
                      <p>{store.address}</p>
                      <p>{store.postalCode} {store.city}</p>
                    </div>
                  </div>

                  <!-- Phone -->
                  <div class="flex items-center gap-3">
                    <svg class="h-6 w-6 text-blue-600 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
                    </svg>
                    <a href={`tel:${store.phone}`} class="hover:text-blue-600 transition-colors">
                      {store.phone}
                    </a>
                  </div>

                  <!-- Email -->
                  <div class="flex items-center gap-3">
                    <svg class="h-6 w-6 text-blue-600 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                    </svg>
                    <a href={`mailto:${store.email}`} class="hover:text-blue-600 transition-colors">
                      {store.email}
                    </a>
                  </div>
                </div>

                <!-- Buttons -->
                <div class="mt-6 flex flex-col sm:flex-row gap-3">
                  <a
                    href={store.mapUrl}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="inline-flex items-center justify-center rounded-md bg-blue-600 px-6 py-3 text-base font-semibold text-white hover:bg-blue-700 transition-colors"
                  >
                    <svg class="mr-2 h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l4.553 2.276A1 1 0 0021 18.382V7.618a1 1 0 00-.553-.894L15 4m0 13V4m0 0L9 7" />
                    </svg>
                    Itinéraire
                  </a>
                  <a
                    href="/contact"
                    class="inline-flex items-center justify-center rounded-md border-2 border-blue-600 px-6 py-3 text-base font-semibold text-blue-600 hover:bg-blue-50 transition-colors"
                  >
                    Nous contacter
                  </a>
                </div>
              </div>
            </div>
          );
        })}
      </div>
    </div>
  </section>

  <!-- Opening Hours Section -->
  <section class="bg-gray-50 py-16">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h2 class="text-3xl font-bold tracking-tight text-gray-900 sm:text-4xl">
          Horaires d'ouverture
        </h2>
        <p class="mt-4 text-lg text-gray-600">
          Nos équipes vous accueillent du lundi au samedi
        </p>
      </div>

      <div class="mx-auto max-w-2xl bg-white rounded-lg shadow-md p-8">
        <div class="space-y-3">
          <div class="flex justify-between items-center py-2 border-b">
            <span class="font-medium text-gray-900">Lundi - Samedi</span>
            <span class="text-gray-600">9h30 - 12h00 / 14h00 - 18h30</span>
          </div>
          <div class="flex justify-between items-center py-2">
            <span class="font-medium text-gray-900">Dimanche</span>
            <span class="text-red-600 font-medium">Fermé</span>
          </div>
        </div>

        <div class="mt-6 p-4 bg-blue-50 rounded-md">
          <p class="text-sm text-blue-800">
            💡 <strong>Conseil :</strong> Nous vous recommandons de prendre rendez-vous pour bénéficier d'un conseil personnalisé.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="bg-blue-900 text-white py-12">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-2xl font-bold mb-4">
        Besoin de conseils pour choisir votre literie ?
      </h2>
      <p class="text-lg text-blue-100 mb-6">
        Nos experts sont là pour vous guider vers le meilleur choix
      </p>
      <div class="flex flex-col gap-4 sm:flex-row sm:justify-center">
        <a
          href="/contact"
          class="inline-flex items-center justify-center rounded-md bg-white px-8 py-3 text-base font-semibold text-blue-900 hover:bg-blue-50 transition-colors"
        >
          Prendre rendez-vous
        </a>
        <a
          href="/produits"
          class="inline-flex items-center justify-center rounded-md border-2 border-white px-8 py-3 text-base font-semibold text-white hover:bg-blue-800 transition-colors"
        >
          Voir nos produits
        </a>
      </div>
    </div>
  </section>
</Layout>
