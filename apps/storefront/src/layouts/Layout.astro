---
import '@fontsource-variable/manrope';
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import JsonLd from '../components/JsonLd.astro';
import CartDrawer from '../components/cart/CartDrawer.tsx';

interface Props {
  title: string;
  description?: string;
  image?: string;
  imageAlt?: string;
  type?: 'website' | 'article' | 'product';
  noindex?: boolean;
}

// 1200x630 social card. Pages that pass their own `image` (products, blog)
// override it; the width/height meta below is only emitted for this default,
// since we can't know the dimensions of a remote product/blog image.
const DEFAULT_OG_IMAGE = '/images/og-default.jpg';

const {
  title,
  description = 'Literie Bleunuit - Spécialiste literie depuis 1994 à Bruay-la-Buissière',
  image = DEFAULT_OG_IMAGE,
  imageAlt = 'Literie Bleunuit — matelas, sommiers et accessoires à Bruay-la-Buissière',
  type = 'website',
  noindex = false,
} = Astro.props;
const isDefaultOgImage = image === DEFAULT_OG_IMAGE;

const siteName = 'Literie Bleunuit';
const fullTitle = `${title} | ${siteName}`;
const siteOrigin = Astro.site ?? new URL(Astro.url.origin);
const canonicalURL = new URL(Astro.url.pathname, siteOrigin);
const imageURL = new URL(image, canonicalURL);

// Site-wide brand entity + website. The per-location FurnitureStore schema
// lives on /contact; this is the parent Organization that ties the brand,
// logo and contact details together for Google's Knowledge Graph.
const organizationJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: siteName,
  url: siteOrigin.href,
  logo: new URL('/images/bleunuit-logo.png', siteOrigin).href,
  description:
    'Spécialiste de la literie depuis 1994 à Bruay-la-Buissière : matelas, sommiers et accessoires.',
  contactPoint: {
    '@type': 'ContactPoint',
    telephone: '+33321532145',
    email: 'contact@bleunuit.fr',
    contactType: 'customer service',
    areaServed: 'FR',
    availableLanguage: 'French',
  },
};
const websiteJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: siteName,
  url: siteOrigin.href,
  inLanguage: 'fr-FR',
};
---

<!doctype html>
<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />
    {noindex && <meta name="robots" content="noindex" />}
    <link rel="icon" type="image/png" sizes="64x64" href="/favicon-64.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <meta name="theme-color" content="#0f2c6e" />
    <link rel="sitemap" href="/sitemap.xml" />
    <meta name="generator" content={Astro.generator} />

    <meta property="og:site_name" content={siteName} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content={type} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:image" content={imageURL} />
    <meta property="og:image:alt" content={imageAlt} />
    {isDefaultOgImage && <meta property="og:image:width" content="1200" />}
    {isDefaultOgImage && <meta property="og:image:height" content="630" />}
    <meta property="og:locale" content="fr_FR" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={imageURL} />
    <meta name="twitter:image:alt" content={imageAlt} />

    <JsonLd data={organizationJsonLd} />
    <JsonLd data={websiteJsonLd} />
    <slot name="head" />
  </head>
  <body class="flex min-h-screen flex-col overflow-x-hidden">
    <Header />
    <main class="flex-1">
      <slot />
    </main>
    <Footer />
    <CartDrawer client:only="react" />
  </body>
</html>
